# SocioSim environment configuration — SAFE PLACEHOLDERS ONLY.
# Copy to .env and fill in as needed; nothing here is required for the
# default loopback research workflow. Never commit a real .env.

# Required ONLY for non-loopback web binds (run.py --web --bind ...).
# The token travels as a cleartext HTTP header — front with a
# TLS-terminating reverse proxy on untrusted networks (see SECURITY.md).
SOCIOSIM_ACCESS_TOKEN=

# Comma-separated hostnames/IPs clients will use; required with a
# non-loopback bind.
SOCIOSIM_ALLOWED_HOSTS=

# Comma-separated private hosts allowed as llm_base_url targets
# (loopback LLM servers need no entry).
SOCIOSIM_LLM_ALLOWED_HOSTS=

# Optional: enables content_mode="claude" (never stored or logged).
ANTHROPIC_API_KEY=
